# Copy this file to your PROJECT ROOT (where you run shellie) and fill in values.
# Example: cd ~/Code/my-app && cp /path/to/shellie/.env.example .env
# Chat and Cognee use separate LLM settings — see README.md for details.

# --- LLM (chat agent via LangChain — talks directly to LLM_ENDPOINT) ---

LLM_MODEL="nvidia/your-chat-model-id"

# LLM_MODEL="meta/llama-3.1-8b-instruct"
# LLM_MODEL="meta/llama-3.3-70b-instruct"

LLM_ENDPOINT="https://integrate.api.nvidia.com/v1"

LLM_API_KEY="nvapi-your-key-here"

# --- Ollama (local chat) — swap with block above to test local models ---
# LLM_API_KEY="ollama"
# LLM_ENDPOINT="http://localhost:11434/v1"
# LLM_MODEL="llama3.1:latest"
# LLM_MODEL="qwen2.5:7b"

# --- Cognee (optional long-term memory — extra LLM/embedding calls) ---
# Install package: pip install 'shellie[cognee]'  or  pipx inject shellie cognee
# Per project: set COGNEE_ENABLED=1 and fill COGNEE_* below. Use COGNEE_ENABLED=0 to
# disable without uninstalling (chat + session SQLite still work).

COGNEE_ENABLED=1

# --- Cognee LLM (remember/recall graph building — routed via LiteLLM) ---
# hosted_vllm/ prefix tells LiteLLM to use COGNEE_LLM_ENDPOINT (NVIDIA NIM).

COGNEE_LLM_PROVIDER="custom"
COGNEE_LLM_MODEL="hosted_vllm/nvidia/your-chat-model-id"
COGNEE_LLM_ENDPOINT="https://integrate.api.nvidia.com/v1"
COGNEE_LLM_API_KEY="nvapi-your-key-here"

# COGNEE_LLM_MODEL="hosted_vllm/meta/llama-3.1-8b-instruct"
# COGNEE_LLM_MODEL="hosted_vllm/meta/llama-3.3-70b-instruct"

# Ollama Cognee LLM — swap with block above when using local chat models
# COGNEE_LLM_PROVIDER="ollama"
# COGNEE_LLM_MODEL="llama3.1:latest"
# COGNEE_LLM_ENDPOINT="http://localhost:11434/v1"
# COGNEE_LLM_API_KEY="ollama"

# --- Cognee embeddings (remember/recall vector search) ---
# openai_compatible bypasses LiteLLM embedding quirks with NVIDIA endpoints.

COGNEE_EMBEDDING_PROVIDER="openai_compatible"
COGNEE_EMBEDDING_MODEL="nvidia/nv-embed-v1"
COGNEE_EMBEDDING_ENDPOINT="https://integrate.api.nvidia.com/v1"
COGNEE_EMBEDDING_API_KEY="nvapi-your-key-here"
COGNEE_EMBEDDING_DIMENSIONS="4096"

# Ollama Cognee embeddings — swap with block above when using local models
# COGNEE_EMBEDDING_PROVIDER="ollama"
# COGNEE_EMBEDDING_MODEL="nomic-embed-text:latest"
# COGNEE_EMBEDDING_ENDPOINT="http://localhost:11434/api/embed"
# COGNEE_EMBEDDING_API_KEY="ollama"
# COGNEE_EMBEDDING_DIMENSIONS="768"

# --- Optional ---
# AGENT_DEBUG=1
